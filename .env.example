# Get keys from:
# - Serper: https://serper.dev/ (free tier)
# - Browserless: https://www.browserless.io/ (free tier)
SERPER_API_KEY="your_serper_api_key"
BROWSERLESS_API_KEY="your_browserless_api_key"

# Ollama configuration
# - MODEL should match `ollama list` (e.g. "llama3.1:8b", "mistral", "qwen2.5:7b")
MODEL="openhermes"
# If Ollama runs elsewhere (or non-default port), set:
OLLAMA_BASE_URL="http://localhost:11434"